FINNHUB_API_KEY=
FINNHUB_SECRET=

FINNHUB_SUBSCRIPTIONS=AAPL,AMZN,BINANCE:BTCUSDT,IC MARKETS:1
FINNHUB_RECONNECT_SECONDS=5

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trades
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_CONNECT_RETRY_SECONDS=2

LOG_LEVEL=INFO
WEBSOCKET_TRACE=false

WRITE_QUEUE_MAXSIZE=20000
WRITE_BATCH_SIZE=250
WRITE_FLUSH_SECONDS=1.0
WRITE_RETRY_SECONDS=2
WRITE_QUEUE_PUT_TIMEOUT=1.0

NEWS_LOOKBACK_DAYS=1
SUMMARY_INTERVAL_MINUTES=5,15,60
CURATION_LOOKBACK_HOURS=24
NEWS_EVENT_LOOKBACK_HOURS=48
EVENT_WINDOW_BEFORE_MINUTES=15
EVENT_WINDOW_AFTER_MINUTES=60
